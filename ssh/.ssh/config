# -----------------------------------------------
# SSH Config - 1Password Agent
# -----------------------------------------------
# All private keys are stored in 1Password.
# The agent matches keys automatically via public keys.
#
# IPs are stored in ~/.ssh/hosts.local (not in this repo).
# See hosts.local.template for the format.
# -----------------------------------------------

Include ~/.ssh/hosts.local

