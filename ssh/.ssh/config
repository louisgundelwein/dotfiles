# -----------------------------------------------
# SSH Config - 1Password Agent + local key fallback
# -----------------------------------------------
# Keys are managed by 1Password SSH Agent when available.
# Local IdentityFile entries serve as fallback.
#
# IPs are stored in ~/.ssh/hosts.local (not in this repo).
# See hosts.local.template for the format.
# -----------------------------------------------

Include ~/.ssh/hosts.local

Host ucm-staging
  User root
  IdentityFile ~/.ssh/id_ucm_staging
  IdentityAgent ~/.1password/agent.sock

Host ucm-staging-new
  User root
  IdentityFile ~/.ssh/id_ucm_staging_new
  IdentityAgent ~/.1password/agent.sock

Host ucm-panel-staging
  User root
  IdentityFile ~/.ssh/id_ucm_panel_staging_old
  IdentityAgent ~/.1password/agent.sock

Host ucm-prod
  User root
  IdentityFile ~/.ssh/id_ucm
  IdentityAgent ~/.1password/agent.sock

Host ucm-panel-prod-old
